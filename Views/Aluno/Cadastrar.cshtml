@model CadastroAluno.Models.Aluno

@{
    ViewData["Title"] = "Cadastro de Aluno";
}

<div class="container mt-4">
    <h2>Cadastro de Aluno</h2>
    <hr />

    <form asp-action="Cadastrar" method="post">
        @Html.AntiForgeryToken()

        <div class="mb-3">
            <label asp-for="Nome" class="form-label"></label>
            <input asp-for="Nome" class="form-control" placeholder="Ex.: Maria Silva" />
            <span asp-validation-for="Nome" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Email" class="form-label"></label>
            <input asp-for="Email" class="form-control" placeholder="aluno@email.com" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="RA" class="form-label"></label>
            <input asp-for="RA" class="form-control" placeholder="Ex.: 12345678" />
            <span asp-validation-for="RA" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="DataNascimento" class="form-label"></label>
            <input asp-for="DataNascimento" class="form-control" type="date" />
            <span asp-validation-for="DataNascimento" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Curso" class="form-label"></label>
            <select asp-for="Curso" class="form-select">
                <option value="">-- Selecione --</option>
                <option>Análise e Desenvolvimento de Sistemas</option>
                <option>Ciência da Computação</option>
                <option>Engenharia de Software</option>
                <option>Sistemas de Informação</option>
            </select>
            <span asp-validation-for="Curso" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-primary">Cadastrar Aluno</button>
    </form>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
